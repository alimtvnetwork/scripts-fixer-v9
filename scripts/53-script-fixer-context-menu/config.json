    "install-python": "Languages & Runtimes",
    "install-golang": "Languages & Runtimes",
    "install-cpp": "Languages & Runtimes",
    "install-php": "Languages & Runtimes",
    "install-flutter": "Languages & Runtimes",
    "install-dotnet": "Languages & Runtimes",
    "install-java": "Languages & Runtimes",
    "install-rust": "Languages & Runtimes",
    "install-python-libs": "Languages & Runtimes",
    "install-git": "Git",
