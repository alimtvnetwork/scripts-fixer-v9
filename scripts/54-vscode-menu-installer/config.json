{
  "_comment": "VS Code context menu installer/uninstaller. The 'registryPaths' values per edition form the STRICT path allow-list used by uninstall.ps1 -- only these exact keys are deleted, never their siblings.",
  "enabled": true,
  "enabledEditions": ["stable", "insiders"],
  "confirmBeforeLaunch": {
    "_comment": "Optional: route every leaf through scripts/shared/confirm-launch.ps1 (Invoke-ConfirmedCommand variant -- same countdown / Ctrl+C / any-key behavior script 53 uses). When 'enabled' is true the install writer wraps each commandTemplates.<target> with a pwsh launcher that runs the countdown then dispatches the original VS Code command unchanged via cmd.exe /c. Set 'enabled': false (default) to keep direct-launch behavior.",
    "enabled": false,
    "countdownSeconds": 5,
    "shellPreferred": "pwsh",
    "shellLegacyPath": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
    "wrapperTemplate": "\"{shellExe}\" -NoProfile -ExecutionPolicy Bypass -Command \". '{repoRoot}\\scripts\\shared\\confirm-launch.ps1'; Invoke-ConfirmedCommand -CommandLine '{innerCommand}' -Label '{leafLabel}' -CountdownSeconds {countdown}"
  },
  "editions": {
    "stable": {
      "label": "Open with Code",
      "vsCodePath": "%LOCALAPPDATA%\\Programs\\Microsoft VS Code\\Code.exe",
      "registryPaths": {
        "file":       "Registry::HKEY_CLASSES_ROOT\\*\\shell\\VSCode",
        "directory":  "Registry::HKEY_CLASSES_ROOT\\Directory\\shell\\VSCode",
        "background": "Registry::HKEY_CLASSES_ROOT\\Directory\\Background\\shell\\VSCode"
      },
      "commandTemplates": {
        "file":       "\"{exe}\" \"%1\"",
        "directory":  "\"{exe}\" \"%V\"",
        "background": "\"{exe}\" \"%V\""
      }
    },
    "insiders": {
      "label": "Open with Code - Insiders",
      "vsCodePath": "%LOCALAPPDATA%\\Programs\\Microsoft VS Code Insiders\\Code - Insiders.exe",
      "registryPaths": {
        "file":       "Registry::HKEY_CLASSES_ROOT\\*\\shell\\VSCodeInsiders",
        "directory":  "Registry::HKEY_CLASSES_ROOT\\Directory\\shell\\VSCodeInsiders",
        "background": "Registry::HKEY_CLASSES_ROOT\\Directory\\Background\\shell\\VSCodeInsiders"
      },
      "commandTemplates": {
        "file":       "\"{exe}\" \"%1\"",
        "directory":  "\"{exe}\" \"%V\"",
        "background": "\"{exe}\" \"%V\""
      }
    }
  }
}
